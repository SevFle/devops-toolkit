name: OWASP Audit
on:
  schedule:
    - cron: '0 5 * * 1'
  workflow_dispatch:
  pull_request:
    types: [opened, synchronize, reopened, ready_for_review]
jobs:
  audit:
    if: ${{ github.event_name != 'pull_request' || !github.event.pull_request.draft }}
    uses: SevFle/devops-toolkit/.github/workflows/ai-owasp-audit.yml@main
    secrets: inherit
