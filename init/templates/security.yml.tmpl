name: Security
on:
  pull_request:
    types: [opened, synchronize, reopened, ready_for_review]
  schedule:
    - cron: '0 3 * * 1'
  workflow_dispatch:
jobs:
  security:
    if: ${{ github.event_name != 'pull_request' || !github.event.pull_request.draft }}
    uses: SevFle/devops-toolkit/.github/workflows/security.yml@main
    with:
      scan_docker: {{SCAN_DOCKER}}
    secrets: inherit
